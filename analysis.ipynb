import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

# ----------------------------------------------------------
# Load Dataset
# ----------------------------------------------------------

# Make sure hotel_bookings.csv is in the same folder
df = pd.read_csv("hotel_bookings.csv")

print("="*60)
print("HOTEL BOOKING DEMAND DATASET")
print("="*60)

# ----------------------------------------------------------
# Dataset Overview
# ----------------------------------------------------------

print("\nFirst 5 Rows")
print(df.head())

print("\nLast 5 Rows")
print(df.tail())

# ----------------------------------------------------------
# Dataset Shape
# ----------------------------------------------------------

print("\nDataset Shape")
print(df.shape)

print(f"\nRows    : {df.shape[0]}")
print(f"Columns : {df.shape[1]}")

# ----------------------------------------------------------
# Column Names
# ----------------------------------------------------------

print("\nColumn Names")
print(df.columns.tolist())

# ----------------------------------------------------------
# Data Types
# ----------------------------------------------------------

print("\nData Types")
print(df.dtypes)

# ----------------------------------------------------------
# Missing Values
# ----------------------------------------------------------

print("\nMissing Values")
print(df.isnull().sum())

print("\nTotal Missing Values")
print(df.isnull().sum().sum())

# ----------------------------------------------------------
# Duplicate Rows
# ----------------------------------------------------------

print("\nDuplicate Rows")
print(df.duplicated().sum())

# ----------------------------------------------------------
# Summary Statistics (Numerical)
# ----------------------------------------------------------

print("\nSummary Statistics (Numerical)")
print(df.describe())

# ----------------------------------------------------------
# Summary Statistics (Categorical)
# ----------------------------------------------------------

print("\nSummary Statistics (Categorical)")
print(df.describe(include='object'))

# ----------------------------------------------------------
# Unique Values
# ----------------------------------------------------------

print("\nUnique Values in Each Column")
print(df.nunique())

# ----------------------------------------------------------
# Target Variable
# ----------------------------------------------------------

print("\nTarget Variable : is_canceled")

print("\nBooking Cancellation Count")
print(df["is_canceled"].value_counts())

print("\nBooking Cancellation Percentage")
print((df["is_canceled"].value_counts(normalize=True)*100).round(2))

# ----------------------------------------------------------
# Correlation
# ----------------------------------------------------------

print("\nCorrelation Matrix")
print(df.corr(numeric_only=True))

# ----------------------------------------------------------
# Basic Visualizations
# ----------------------------------------------------------

plt.figure(figsize=(6,4))
df["is_canceled"].value_counts().plot(kind="bar")
plt.title("Booking Cancellation")
plt.xlabel("Cancelled")
plt.ylabel("Count")
plt.show()

plt.figure(figsize=(8,5))
df["hotel"].value_counts().plot(kind="bar")
plt.title("Hotel Type Distribution")
plt.xlabel("Hotel")
plt.ylabel("Bookings")
plt.show()

plt.figure(figsize=(8,5))
df["arrival_date_month"].value_counts().sort_index().plot(kind="bar")
plt.title("Bookings by Month")
plt.xlabel("Month")
plt.ylabel("Bookings")
plt.xticks(rotation=45)
plt.show()

